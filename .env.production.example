# ========================================
# W简历 (W-Resume) 生产环境配置示例
# ========================================

# --- 基础配置 ---
TZ="Asia/Shanghai"
# 修改为服务器实际域名
APP_URL="https://resume.yourdomain.com"
# Printer 内部访问地址（Docker网络内）
PRINTER_APP_URL="http://reactive_resume:3000"

# --- PDF 生成服务 ---
# 使用 Docker 内部的 browserless 服务
PRINTER_ENDPOINT="ws://browserless:3000?token=your-secure-token"

# --- 数据库 ---
# 修改为强密码！
DATABASE_URL="postgresql://postgres:YOUR_STRONG_PASSWORD@postgres:5432/postgres"

# --- 认证 (重要！必须修改) ---
# 生成命令: openssl rand -hex 32
AUTH_SECRET="your-32-byte-hex-secret-key-here-change-immediately"

# --- 邮件配置 (可选) ---
# 用于注册验证、密码重置
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@yourdomain.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="W简历 <noreply@yourdomain.com>"
SMTP_SECURE="true"

# --- 功能开关 ---
# 禁用注册 (如需邀请制)
FLAG_DISABLE_SIGNUPS="false"
# 禁用邮箱登录 (仅保留社交登录)
FLAG_DISABLE_EMAIL_AUTH="false"

# ========================================
# 部署步骤:
# 1. 复制此文件为 .env 并修改配置
# 2. 修改 compose.yml 中的环境变量
# 3. 运行: docker compose up -d --build
# ========================================